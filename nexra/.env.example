# Core runtime
SPRING_PROFILES_ACTIVE=dev
APPLICATION_NAME=nexra

# Shared datasource used by the modular monolith in production
AUTH_DB_URL=jdbc:mysql://localhost:3306/nexra
AUTH_DB_USERNAME=root
AUTH_DB_PASSWORD=change-me

# Auth module
AUTH_JWT_SECRET=change-me-to-a-32-char-minimum-secret
AUTH_OAUTH2_ISSUER=http://localhost:8081
AUTH_OAUTH2_DEFAULT_CLIENT_SECRET=change-me
AUTH_OAUTH2_KEYSTORE_LOCATION=
AUTH_OAUTH2_KEYSTORE_PASSWORD=
AUTH_OAUTH2_KEY_ALIAS=
AUTH_OAUTH2_KEY_PASSWORD=

# Redis and mail for auth production mode
AUTH_REDIS_HOST=localhost
AUTH_REDIS_PORT=6379
AUTH_REDIS_PASSWORD=
AUTH_MAIL_FROM=noreply@nexra.local
AUTH_SMTP_HOST=smtp.example.com
AUTH_SMTP_PORT=587
AUTH_SMTP_USERNAME=user
AUTH_SMTP_PASSWORD=change-me

# Employee-core production validator
EMPLOYEE_CORE_DB_URL=jdbc:mysql://localhost:3306/nexra
EMPLOYEE_CORE_DB_USERNAME=root
EMPLOYEE_CORE_DB_PASSWORD=change-me
